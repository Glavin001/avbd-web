{
  "name": "avbd-web",
  "version": "0.1.0",
  "description": "WebGPU-accelerated Augmented Vertex Block Descent physics engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./2d": {
      "import": "./dist/2d/index.js",
      "types": "./dist/2d/index.d.ts"
    },
    "./3d": {
      "import": "./dist/3d/index.js",
      "types": "./dist/3d/index.d.ts"
    }
  },
  "scripts": {
    "embed-shaders": "tsx scripts/embed-shaders.ts",
    "prebuild": "npm run embed-shaders",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/browser/demo-e2e.spec.ts",
    "test:gpu": "playwright test",
    "test:all": "vitest run && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "dev": "vite examples/",
    "build:demo": "npm run embed-shaders && cd examples && npx vite build"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.1",
    "@webgpu/types": "^0.1.52",
    "three": "^0.183.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": [
    "physics",
    "webgpu",
    "avbd",
    "vbd",
    "rigid-body",
    "simulation",
    "compute-shader"
  ]
}
